{
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "claudeMdExcludes": [
    "**/.claude/CLAUDE.md"
  ],
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "filesystem": {
      "allowWrite": ["."],
      "denyRead": ["~/.aws", "~/.ssh", "~/.gnupg", "../"]
    },
    "network": {
      "allowedDomains": [
        "api.anthropic.com"
      ]
    }
  },
  "extraKnownMarketplaces": {
    "personas": {
      "source": {
        "source": "github",
        "repo": "kickinrad/personas"
      }
    },
    "core": {
      "source": {
        "source": "directory",
        "path": "/home/wilst/projects/markets/core"
      },
      "autoUpdate": true
    },
    "obsidian-skills": {
      "source": {
        "source": "github",
        "repo": "kepano/obsidian-skills"
      }
    }
  },
  "enabledPlugins": {
    "persona-manager@personas": true,
    "vault@core": true,
    "obsidian@obsidian-skills": true
  }
}
