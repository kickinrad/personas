{
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "filesystem": {
      "allowWrite": ["."],
      "denyRead": ["~/.aws", "~/.ssh", "~/.gnupg", "../"]
    },
    "network": {
      "allowedDomains": [
        "api.anthropic.com"
      ]
    }
  },
  "extraKnownMarketplaces": {
    "personas": {
      "source": {
        "source": "github",
        "repo": "kickinrad/personas"
      }
    }
  },
  "enabledPlugins": {
    "persona-manager@personas": true
  }
}
