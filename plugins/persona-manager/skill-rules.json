{
  "description": "Activation rules for persona-manager skills",
  "rules": {
    "persona-dev": {
      "kind": "skill",
      "type": "process",
      "enforcement": "must",
      "priority": "high",
      "activationHint": "Skill('persona-manager:persona-dev')",
      "promptTriggers": {
        "keywords": ["persona", "new persona", "create a persona", "add a persona", "build a persona", "design a persona", "persona for"],
        "intentPatterns": ["(create|build|design|add|make|new).*?persona", "persona.*?(for|that|who|to)", "i want a persona", "help me.*?persona"]
      },
      "fileTriggers": {
        "pathPatterns": ["**/.personas/**"],
        "contentPatterns": []
      }
    },
    "persona-dashboard": {
      "kind": "skill",
      "type": "process",
      "enforcement": "must",
      "priority": "medium",
      "activationHint": "Skill('persona-manager:persona-dashboard')",
      "promptTriggers": {
        "keywords": ["dashboard", "persona dashboard", "task board", "visual status"],
        "intentPatterns": ["(add|set up|create|build|install).*?dashboard", "dashboard.*?(for|to|persona)", "want a dashboard", "task board"]
      },
      "fileTriggers": {
        "pathPatterns": [],
        "contentPatterns": []
      }
    }
  }
}
