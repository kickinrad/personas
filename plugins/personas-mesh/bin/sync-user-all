#!/usr/bin/env bash
# sync-user-all: iterate personas under ~/.personas/ and reconcile each user/
# directory with its Windows-side counterpart.
#
# Usage: sync-user-all [--verbose]
#
# Skips: piper (lives in the vault, redirected via .persona-cwd), dotfile
# entries, and personas where one side is missing (handled in sync-user-persona).
#
# Exit codes:
#   0  all personas synced cleanly (or skipped)
#   1  precondition error (sibling script not found/executable)
#   2  one or more personas reported failure

set -uo pipefail

SCRIPT_DIR=$(dirname "$(readlink -f "$0")")
SCRIPT_NAME=$(basename "$0")
SIBLING_NAME="${SCRIPT_NAME/sync-user-all/sync-user-persona}"
SYNC_ONE="$SCRIPT_DIR/$SIBLING_NAME"
[ -x "$SYNC_ONE" ] || { printf 'sync-user-all: %s not executable\n' "$SYNC_ONE" >&2; exit 1; }

VERBOSE=0
for arg in "$@"; do
  case "$arg" in
    --verbose|-v) VERBOSE=1 ;;
    -*) printf 'sync-user-all: unknown flag: %s\n' "$arg" >&2; exit 1 ;;
  esac
done

verbose_flag=()
[ "$VERBOSE" = "1" ] && verbose_flag=(--verbose)

any_fail=0
for dir in "${HOME}"/.personas/*/; do
  persona=$(basename "$dir")
  case "$persona" in
    piper) continue ;;       # vault-redirect — see sync-all for the matching git-side skip
    .*) continue ;;          # archive / sync-conflicts / hidden entries
  esac
  rc=0
  "$SYNC_ONE" "${verbose_flag[@]}" "$persona" || rc=$?
  if [ "$rc" != "0" ]; then
    printf '  %s: failed (exit %d)\n' "$persona" "$rc" >&2
    any_fail=1
  fi
done

[ "$any_fail" = "1" ] && exit 2
exit 0
