{
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "filesystem": {
      "allowWrite": ["."],
      "denyRead": ["~/.aws", "~/.ssh", "~/.gnupg", "../"]
    },
    "network": {
      "allowedDomains": [
        "api.anthropic.com",
        "*.googleapis.com",
        "*.monarchmoney.com",
        "*.finnhub.io",
        "*.alphavantage.co",
        "*.yahoo.com",
        "fc.yahoo.com"
      ]
    }
  }
}
